TOOLS:
  delete_person(name?: string) -> object
    description: "Tool responsible to delete a person"
    type: http
    params:
      name:
        description: "It is the name of the person to delete"
    endpoint: "https://httpbun.com/delete"
    method: DELETE
    body_type: json
    body: |
      {
        "name": "{{input.name}}"
      }
    headers:
      Content-Type: application/json